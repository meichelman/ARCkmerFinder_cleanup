import sys
import os
import re
from pathlib import Path


configfile: "config.yaml"


# Configuration variables
szAssemblyPath = config["assembly"]
szMerylDatabase = config["existing_meryl_database_path" ]
nWindowSize = config["window_size"] # probably can't play with this until the plotting scripts are cleaned up
szAssemblyBasename = os.path.basename( szAssemblyPath )
