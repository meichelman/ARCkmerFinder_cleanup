rule addColors:
	input: ccount=szKmerCountInWindows, lleft=szFileOfContigsToDisplayOnLeft, rright=szFileOfContigsToDisplayOnRight
	output: szKmerCountInWindowsWithColor
	localrule: True
	run:
		szCommand = f"cat {{input.ccount}} | ./addColors3.py --szContigsToDisplayOnLeft {szFileOfContigsToDisplayOnLeft} --szContigsToDisplayOnRight {szFileOfContigsToDisplayOnRight} >{{output}}"
		print( "about to execute: " + szCommand )
		shell( szCommand )


# szKmerCountBedWithWindow differs from szKmerCountInWindows in that
# each kmer has a line while szKmerCountInWindows has a single line for
# each 2kb window

# szKmerCountInWindows has a number, for each 2kb window, of kmers from
# PNG16_vs_Chagyrskaya_minus_HG03516_greater_than_5.  If a kmer is found
# more than once in the 2kb window, it is counted more than once?  Yes.
# meryl-lookup notes for each kmer, how many times it is found in the
# reads (by the meryl database).  But that count is ignored by this
# pipeline.  Each kmer found is assigned to a 2kb window.  bedtools
# groupby then counts how many kmers for each 2kb are found in the
# meryl database.  Some of these kmers may be the same.  We don't know
# and don't care.  Just how many kmers in each 2kb region are found in
# the meryl database.


rule groupby_kmer_counts_in_windows:
	input: szBedToGroup=szKmerCountBedWithWindow, szFlag=szAssemblyBasename + "_" + str( config["name_of_subtracted_meryl_database" ] ) + ".bed.sorted_flag"
	output: szKmerCountInWindows
	localrule: True
	run:
		szCommand = "module load bedtools/2.29.2 && bedtools groupby -i {input.szBedToGroup} -g 6,7,8 -o count -c 5 >{output}"
		print( "about to execute: " + szCommand )
		shell( szCommand )

rule assign_kmer_counts_to_windows:
	input: szWindowsAcrossGenome, szKmerCountBed
	output: szKmerCountBedWithWindow
	resources:
		threads=10,
		mem=100
	run:
		# check that szKmerCountBed is sorted
		szCommand = "sort -k1,1V -k2,2n -c " + szKmerCountBed 
		print( "about to execute: " + szCommand )
		shell( szCommand )

		# check that szWindowsAcrossGenome is sorted
		# szCommand = "sort -k1,1V -k2,2n -c " + szWindowsAcrossGenome
                szCommand = (
                        "if ! sort -k1,1V -k2,2n -c \"" + szWindowsAcrossGenome + "\" 2>/dev/null; "
                        "then echo sorting \"" + szWindowsAcrossGenome + "\"; "
                        "tmp=$(mktemp); "
                        "sort -k1,1V -k2,2n \"" + szWindowsAcrossGenome + "\" > \"$tmp\" && mv \"$tmp\" \"" + szWindowsAcrossGenome + "\"; "
                        "fi"
                )
		print( "about to execute: " + szCommand )
		shell( szCommand )

		szCommand = "module load bedtools2/2.31.0-gcc-8.2.0-7j35k74 && bedtools intersect -sorted -a " + szKmerCountBed + " -b " + szWindowsAcrossGenome + " -wa -wb >" + szKmerCountBedWithWindow
		print( "about to execute: " + szCommand )
		shell( szCommand )

		# check that the output file is sorted
		szCommand = "sort -k1,1V -k2,2n -c " + szKmerCountBedWithWindow
		print( "about to execute: " + szCommand )
		shell( szCommand )



rule make_windows_across_genome:
	input: szAssemblyFai
	output: szWindowsAcrossGenome
	localrule: True
	run:
		szCommand = "module load bedtools2/2.31.0-gcc-8.2.0-7j35k74 && bedtools makewindows -g " + str( input ) + " -w " + str( nWindowSize ) + " >" + szWindowsAcrossGenome
		print( "about to execute: " + szCommand )
		shell( szCommand )

from pathlib import Path

from pathlib import Path

def is_directly_in_cwd(file_path):
    """
    Checks if the file_path is located directly in the Current Working Directory (CWD),
    excluding files in subdirectories.
    
    Args:
        file_path (str): The path to check (should represent a file).
        
    Returns:
        bool: True if the file is an immediate member of the CWD.
    """

    full_path = os.path.abspath(file_path)

    file_dir = os.path.dirname(full_path)

    print( file_dir )

    current_dir = os.getcwd()

    if ( file_dir == current_dir):
       print( "the path is in the cwd" )
       return True
    else:
       print("the path is not in the cwd" )
       return False




rule make_fai:
	input: config["assembly"]
	output: szAssemblyFai
	localrule: True
	run:
		bIsInCWD = is_directly_in_cwd( str(input ) )
		print( "is in current directory ", bIsInCWD )
		if ( not is_directly_in_cwd( str(input ) ) ):
			szCommand = f"ln -sf {input}"
			print( "about to execute: " + szCommand )
			shell( szCommand )
                        
		szCommand = f"module load samtools/1.20 && samtools faidx {szAssemblyBasename}"
		print( "about to execute: " + szCommand )
		shell( szCommand )

rule check_bed_sorted:
	output: szAssemblyBasename + "_" + str( config["name_of_subtracted_meryl_database" ] ) + ".bed.sorted_flag"
	input: szAssemblyBasename + "_" + str( config["name_of_subtracted_meryl_database" ] ) + ".bed"
	resources:
            threads=1,
            mem=10,
            disk=10
	run:
            szCommand = (
                "if ! sort -k1,1V -k2,2n -c \"" + str(input) + "\" 2>/dev/null; "
                "then echo sorting \"" + str(input) + "\"; "
                "tmp=$(mktemp); "
                "sort -k1,1V -k2,2n \"" + str(input) + "\" > \"$tmp\" && mv \"$tmp\" \"" + str(input) + "\"; "
                "fi"
                " && touch " + str( output )
            )
            print( "about to execute: " + szCommand )
            shell( szCommand )

# Changed the command below to what is above for catching the sorting error and performing the sorting.
# This way writes the sorted file to a temporary file, then moves the temp file to replace the original
# unsorted file in order to maintain the file name for subsequent rules.
# szCommand = "sort -k1,1V -k2,2n -c <" + str( input ) + " && touch " + str( output ) 


rule convert_wig_to_bed:
	input: szAssemblyBasename + "_" + str( config["name_of_subtracted_meryl_database" ] ) + ".wig"
	output: szAssemblyBasename + "_" + str( config["name_of_subtracted_meryl_database" ] ) + ".bed"
	resources:
		threads=4,
		mem=15
	run:
		szCommand = "module load bedops/2.4.41 && wig2bed --do-not-sort <" + str( input ) + " >" + str( output )
		print( "about to execute: " + szCommand )
		shell( szCommand )

# I saw this using 600% cpu and 12G memory so decreasing it
# but then 14 out of 260 failed because they used more than 20G of memory so
# increasing it to 30G
rule make_meryl_lookup:
	input:  str( config["name_of_subtracted_meryl_database" ] ) + ".meryl.flag"
	output: szAssemblyBasename + "_" + str( config["name_of_subtracted_meryl_database" ] ) + ".wig"
	resources:
		threads=7,
		mem=30
	run:
		szMerylDatabase = config["existing_meryl_database_path" ]
		szCommand = "module load meryl/1.4.1 && meryl-lookup -wig-count -output " + str( output ) + " -sequence " + config["assembly"] + " -mers " +  szMerylDatabase 
		print( "about to execute: " + szCommand )
		shell( szCommand )

rule count_meryl_database_after_removing_low_occurrence_kmers:
	input: str( config["name_of_subtracted_meryl_database" ] ) + ".meryl.flag"
	output: "kmers_not_counting_repeats_after_removing_low_occurrence_kmers.txt"
	resources:
		#threads=40
		# meryl print did not speed up (seemed to even slow down) when using more threads
		threads=1
	run:
		# changed 2025.08.22 DG since szMerylDatabase pointed to non-existing meryl database and meryl print created about 60 empty files
		#szMerylDatabase = re.sub( r'.flag$', '', str( input ) )

		szMerylDatabase = config["existing_meryl_database_path" ]
		
		szTempOutput = str( output ) + ".tmp"

		szCommand = "module load meryl/1.4.1 && meryl print " + szMerylDatabase + " | wc -l >" + szTempOutput
		print( "about to execute: " + szCommand )
		shell( szCommand )

		szCommand = "cat " + szTempOutput + " | awk '{{printf \"%\\47i\\n\", $1 }}' >> " + szTempOutput
		print( "about to execute: " + szCommand )
		shell( szCommand )

		szCommand = "mv " + szTempOutput + " " + str( output )
		print( "about to execute: " + szCommand )
		shell( szCommand )


rule assemblyFaiToBed:
	input: szAssemblyFai
	output: szAssemblyBedFile
	localrule: True
	run:
		szCommand = "cat {input} | awk '{{print $1\"\t1\t\"$2}}' >{output}"
		print( "about to execute: " + szCommand )
		shell( szCommand )


